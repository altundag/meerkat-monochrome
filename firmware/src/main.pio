.program capture

.wrap_target
    wait 1 gpio 5
    wait 0 gpio 5
    mov osr, pins
    in osr, 8
    out null, 8
    in osr, 2

    wait 1 gpio 5
    wait 0 gpio 5
    mov osr, pins
    in osr, 6
    out null, 6
    in osr, 4

    wait 1 gpio 5
    wait 0 gpio 5
    mov osr, pins
    in osr, 4
    out null, 4
    in osr, 6

    wait 1 gpio 5
    wait 0 gpio 5
    mov osr, pins
    in osr, 2
    out null, 2
    in osr, 8
.wrap
